<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.guide.mapper.GuideWorkShiftMapper">
    
    <resultMap type="GuideWorkShift" id="GuideWorkShiftResult">
        <result property="shiftId"    column="shift_id"    />
        <result property="guideId"    column="guide_id"    />
        <result property="shiftDate"    column="shift_date"    />
        <result property="shiftType"    column="shift_type"    />
        <result property="startTime"    column="start_time"    />
        <result property="endTime"    column="end_time"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectGuideWorkShiftVo">
        select shift_id, guide_id, shift_date, shift_type, start_time, end_time, status, create_by, create_time, update_by, update_time, remark, del_flag from guide_work_shift
    </sql>

    <select id="selectGuideWorkShiftList" parameterType="GuideWorkShift" resultMap="GuideWorkShiftResult">
        <include refid="selectGuideWorkShiftVo"/>
        <where>  
            <if test="guideId != null "> and guide_id = #{guideId}</if>
            <if test="shiftDate != null "> and shift_date = #{shiftDate}</if>
            <if test="shiftType != null  and shiftType != ''"> and shift_type = #{shiftType}</if>
            <if test="startTime != null "> and start_time = #{startTime}</if>
            <if test="endTime != null "> and end_time = #{endTime}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectGuideWorkShiftByShiftId" parameterType="Long" resultMap="GuideWorkShiftResult">
        <include refid="selectGuideWorkShiftVo"/>
        where shift_id = #{shiftId}
    </select>

    <insert id="insertGuideWorkShift" parameterType="GuideWorkShift" useGeneratedKeys="true" keyProperty="shiftId">
        insert into guide_work_shift
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="guideId != null">guide_id,</if>
            <if test="shiftDate != null">shift_date,</if>
            <if test="shiftType != null and shiftType != ''">shift_type,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="guideId != null">#{guideId},</if>
            <if test="shiftDate != null">#{shiftDate},</if>
            <if test="shiftType != null and shiftType != ''">#{shiftType},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateGuideWorkShift" parameterType="GuideWorkShift">
        update guide_work_shift
        <trim prefix="SET" suffixOverrides=",">
            <if test="guideId != null">guide_id = #{guideId},</if>
            <if test="shiftDate != null">shift_date = #{shiftDate},</if>
            <if test="shiftType != null and shiftType != ''">shift_type = #{shiftType},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where shift_id = #{shiftId}
    </update>

    <delete id="deleteGuideWorkShiftByShiftId" parameterType="Long">
        delete from guide_work_shift where shift_id = #{shiftId}
    </delete>

    <delete id="deleteGuideWorkShiftByShiftIds" parameterType="String">
        delete from guide_work_shift where shift_id in 
        <foreach item="shiftId" collection="array" open="(" separator="," close=")">
            #{shiftId}
        </foreach>
    </delete>
</mapper>