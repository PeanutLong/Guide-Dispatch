<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.guide.mapper.TouristEvaluationMapper">
    
    <resultMap type="TouristEvaluation" id="TouristEvaluationResult">
        <result property="evalId"    column="eval_id"    />
        <result property="groupId"    column="group_id"    />
        <result property="guideId"    column="guide_id"    />
        <result property="score"    column="score"    />
        <result property="content"    column="content"    />
        <result property="tags"    column="tags"    />
        <result property="evalTime"    column="eval_time"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectTouristEvaluationVo">
        select eval_id, group_id, guide_id, score, content, tags, eval_time, create_by, create_time, update_by, update_time, del_flag from tourist_evaluation
    </sql>

    <select id="selectTouristEvaluationList" parameterType="TouristEvaluation" resultMap="TouristEvaluationResult">
        <include refid="selectTouristEvaluationVo"/>
        <where>  
            <if test="groupId != null "> and group_id = #{groupId}</if>
            <if test="guideId != null "> and guide_id = #{guideId}</if>
            <if test="score != null "> and score = #{score}</if>
            <if test="content != null  and content != ''"> and content = #{content}</if>
            <if test="tags != null  and tags != ''"> and tags = #{tags}</if>
            <if test="evalTime != null "> and eval_time = #{evalTime}</if>
        </where>
    </select>
    
    <select id="selectTouristEvaluationByEvalId" parameterType="Long" resultMap="TouristEvaluationResult">
        <include refid="selectTouristEvaluationVo"/>
        where eval_id = #{evalId}
    </select>

    <insert id="insertTouristEvaluation" parameterType="TouristEvaluation" useGeneratedKeys="true" keyProperty="evalId">
        insert into tourist_evaluation
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="groupId != null">group_id,</if>
            <if test="guideId != null">guide_id,</if>
            <if test="score != null">score,</if>
            <if test="content != null">content,</if>
            <if test="tags != null">tags,</if>
            <if test="evalTime != null">eval_time,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="groupId != null">#{groupId},</if>
            <if test="guideId != null">#{guideId},</if>
            <if test="score != null">#{score},</if>
            <if test="content != null">#{content},</if>
            <if test="tags != null">#{tags},</if>
            <if test="evalTime != null">#{evalTime},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateTouristEvaluation" parameterType="TouristEvaluation">
        update tourist_evaluation
        <trim prefix="SET" suffixOverrides=",">
            <if test="groupId != null">group_id = #{groupId},</if>
            <if test="guideId != null">guide_id = #{guideId},</if>
            <if test="score != null">score = #{score},</if>
            <if test="content != null">content = #{content},</if>
            <if test="tags != null">tags = #{tags},</if>
            <if test="evalTime != null">eval_time = #{evalTime},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where eval_id = #{evalId}
    </update>

    <delete id="deleteTouristEvaluationByEvalId" parameterType="Long">
        delete from tourist_evaluation where eval_id = #{evalId}
    </delete>

    <delete id="deleteTouristEvaluationByEvalIds" parameterType="String">
        delete from tourist_evaluation where eval_id in 
        <foreach item="evalId" collection="array" open="(" separator="," close=")">
            #{evalId}
        </foreach>
    </delete>
</mapper>