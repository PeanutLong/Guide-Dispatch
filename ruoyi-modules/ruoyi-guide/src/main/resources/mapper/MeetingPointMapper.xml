<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.guide.mapper.MeetingPointMapper">

    <resultMap type="MeetingPoint" id="MeetingPointResult">
        <result property="pointId"    column="point_id"    />
        <result property="pointName"    column="point_name"    />
        <result property="pointCode"    column="point_code"    />
        <result property="location"    column="location"    />
        <result property="gpsLat"    column="gps_lat"    />
        <result property="gpsLng"    column="gps_lng"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectMeetingPointVo">
        select point_id, point_name, point_code, location, gps_lat, gps_lng, status, create_by, create_time, update_by, update_time, remark, del_flag from meeting_point
    </sql>

    <select id="selectMeetingPointList" parameterType="MeetingPoint" resultMap="MeetingPointResult">
        <include refid="selectMeetingPointVo"/>
        <where>
            <if test="pointName != null  and pointName != ''"> and point_name like concat('%', #{pointName}, '%')</if>
            <if test="pointCode != null  and pointCode != ''"> and point_code = #{pointCode}</if>
            <if test="location != null  and location != ''"> and location = #{location}</if>
            <if test="gpsLat != null "> and gps_lat = #{gpsLat}</if>
            <if test="gpsLng != null "> and gps_lng = #{gpsLng}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>

    <select id="selectMeetingPointByPointId" parameterType="Long" resultMap="MeetingPointResult">
        <include refid="selectMeetingPointVo"/>
        where point_id = #{pointId}
    </select>

    <insert id="insertMeetingPoint" parameterType="MeetingPoint" useGeneratedKeys="true" keyProperty="pointId">
        insert into meeting_point
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="pointName != null and pointName != ''">point_name,</if>
            <if test="pointCode != null">point_code,</if>
            <if test="location != null">location,</if>
            <if test="gpsLat != null">gps_lat,</if>
            <if test="gpsLng != null">gps_lng,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="pointName != null and pointName != ''">#{pointName},</if>
            <if test="pointCode != null">#{pointCode},</if>
            <if test="location != null">#{location},</if>
            <if test="gpsLat != null">#{gpsLat},</if>
            <if test="gpsLng != null">#{gpsLng},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null">#{delFlag},</if>
        </trim>
    </insert>

    <update id="updateMeetingPoint" parameterType="MeetingPoint">
        update meeting_point
        <trim prefix="SET" suffixOverrides=",">
            <if test="pointName != null and pointName != ''">point_name = #{pointName},</if>
            <if test="pointCode != null">point_code = #{pointCode},</if>
            <if test="location != null">location = #{location},</if>
            <if test="gpsLat != null">gps_lat = #{gpsLat},</if>
            <if test="gpsLng != null">gps_lng = #{gpsLng},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where point_id = #{pointId}
    </update>

    <delete id="deleteMeetingPointByPointId" parameterType="Long">
        delete from meeting_point where point_id = #{pointId}
    </delete>

    <delete id="deleteMeetingPointByPointIds" parameterType="String">
        delete from meeting_point where point_id in
        <foreach item="pointId" collection="array" open="(" separator="," close=")">
            #{pointId}
        </foreach>
    </delete>
</mapper>